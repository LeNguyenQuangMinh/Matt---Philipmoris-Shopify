{% comment %}
  Renders a header drawer menu for mobile and desktop.

  Usage:
  {% render 'header-drawer' %}
{% endcomment %}

<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">

{%- liquid
  assign listmenu = section.settings.menu.links
  assign listmenu_size = listmenu.size
  if localization.available_countries.size > 1 and section.settings.show_country or section.settings.show_language and localization.available_languages.size > 1
    assign localization_forms = true
  endif

  assign class_link = 'menu-drawer__menu-item list-menu__item link link--text focus-inset'
  assign class_item_animate = 'menu-drawer__item-animate'
  assign class_link_active = 'menu-drawer__menu-item--active'
  assign keys = 'highlighted_item_,new_label_,sale_label_,hot_label_'
-%}

{%- capture icon_arrow -%}
  <span class="svg-wrapper">
    {{- 'icon-arrow.svg' | inline_asset_content -}}
  </span>
{%- endcapture -%}

<side-drawer
  class="drawer__container drawer drawer--menu fixed top-0 left-0 w-screen h-full z-9 flex no-js-hidden{% if mobile_layout == 'custom' %} side-drawer-container--custom{% endif %}"
  id="Drawer-Menu"
  data-drawer-direction="left"
>
  <div id="Drawer-Overlay-Menu" class="drawer__overlay fixed inset-0 cursor-pointer"></div>
  <header-drawer class="side-drawer{% if mobile_layout == 'custom' %} side-drawer--custom{% endif %}" data-drawer-content data-breakpoint="tablet">
    <div
      class="drawer__inner d-flex flex-column h-full color-{{ color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'accessibility.menu' | t }}"
      tabindex="-1"
    >
    {%- if mobile_layout != 'custom' -%}
    <div class="drawer__header flex justify-between items-center relative" style="--p: var(--padding-xs) 0;">
      <h2 class="drawer__heading break m-0 h5">{{ 'content.menu' | t }}</h2>
      <button
        class="drawer__close block t-button bor-none cursor-pointer"
        type="button"
        onclick="this.closest('side-drawer').close()"
        aria-label="{{ 'accessibility.close_dialog' | t }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>
    {%- endif -%}
      {% comment %} <div class="drawer__header flex justify-end items-center relative" style="--p: 0 0 1.5rem;">
      </div> {% endcomment %}
      {%- if mobile_layout == 'custom' -%}
        <div class="drawer__search-bar" style="padding: 1rem 0 0.5rem;">
          {%- if settings.predictive_search_enabled -%}
            <predictive-search class="search-drawer__form" data-loading-text="{{ 'accessibility.loading' | t }}">
          {%- else -%}
            <search-form class="search-drawer__form">
          {%- endif -%}
          <form action="{{ routes.search_url }}" method="get" role="search" class="search search-drawer__form">
            <div class="predictive-search--center">
              <div class="field">
                <button class="search__button field__button" aria-label="{{ 'content.search' | t }}">
                  <span class="svg-wrapper">
                    {{- 'icon-search.svg' | inline_asset_content -}}
                  </span>
                </button>
                <input
                  class="search__input field__input field__input--focus"
                  id="Search-In-Drawer"
                  type="search"
                  name="q"
                  value="{{ search.terms | escape }}"
                  placeholder="{% if mobile_layout == 'custom' %}SEARCH PRODUCT OR BRAND{% else %} {% endif %}"
                  {%- if settings.predictive_search_enabled -%}
                    role="combobox"
                    aria-expanded="false"
                    aria-owns="predictive-search-results-drawer"
                    aria-controls="predictive-search-results-drawer"
                    aria-haspopup="listbox"
                    aria-autocomplete="list"
                    autocorrect="off"
                    autocomplete="off"
                    autocapitalize="off"
                    spellcheck="false"
                  {%- endif -%}
                >
                {%- if mobile_layout != 'custom' -%}
                  <label class="field__label" for="Search-In-Drawer">{{ 'content.search' | t }}</label>
                {%- endif -%}
                <input type="hidden" name="options[prefix]" value="last">
                <button
                  type="reset"
                  class="reset__button field__button{% if search.terms == blank %} hidden{% endif %}"
                  aria-label="{{ 'content.clear_search_term' | t }}"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-close.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>
            </div>

            {%- if settings.predictive_search_enabled -%}
              <div
                id="predictive-search-results-drawer"
                class="predictive-search predictive-search--header predictive-search--center cus-scrollbar"
                tabindex="-1"
                data-predictive-search
              >
                {% render 'predictive-search-empty-state', shadow_opacity: 0.1 %}
              </div>
              <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
            {%- endif -%}
          </form>
          {%- if settings.predictive_search_enabled -%}
            </predictive-search>
          {%- else -%}
            </search-form>
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="drawer__wrapper menu-drawer relative h-full motion-reduce" style="--p: 1.5rem 0 0;">
        <div class="menu-drawer__navigation-container cus-scrollbar">
          <nav class="menu-drawer__navigation">
            <ul class="menu-drawer__menu has-submenu list-menu" role="list">
              {%- liquid
                assign mega_menu_1 = section.blocks | where: 'type', 'mega_menu_1'
                assign mega_menu_2 = section.blocks | where: 'type', 'mega_menu_2'
                assign mega_menu_3 = section.blocks | where: 'type', 'mega_menu_3'
                assign mega_menu_4 = section.blocks | where: 'type', 'mega_menu_4'
              -%}
              {%- for link in listmenu -%}
                {%- liquid
                  assign has_mega_menu = false
                  assign menu_title = link.title | escape | downcase | handle
                  assign mega_block = null
                  assign mega_type = null

                  for block in mega_menu_1
                    assign block_title = block.settings.menu_item | escape | downcase | handle
                    if block_title == menu_title
                      assign mega_block = block
                      assign mega_type = 'mega_menu_1'
                      assign has_mega_menu = true
                    endif
                  endfor

                  for block in mega_menu_2
                    assign block_title = block.settings.menu_item | escape | downcase | handle
                    if block_title == menu_title
                      assign mega_block = block
                      assign mega_type = 'mega_menu_2'
                      assign has_mega_menu = true
                    endif
                  endfor

                  for block in mega_menu_3
                    assign block_title = block.settings.menu_item | escape | downcase | handle
                    if block_title == menu_title
                      assign mega_block = block
                      assign mega_type = 'mega_menu_3'
                      assign has_mega_menu = true
                    endif
                  endfor

                  for block in mega_menu_4
                    assign block_title = block.settings.menu_item | escape | downcase | handle
                    if block_title == menu_title
                      assign mega_block = block
                      assign mega_type = 'mega_menu_4'
                      assign has_mega_menu = true
                    endif
                  endfor
                -%}
                <menu-drawer class="menu-drawer__list-item" style="--menu-drawer-animation-index: {{ forloop.index }};">
                  {%- if link.links != blank or has_mega_menu -%}
                    <details id="Details-menu-drawer-menu-item-{{ forloop.index }}">
                      <summary
                        id="HeaderDrawer-{{ link.handle }}"
                        class="{{ class_link }}{% if link.child_active %} {{ class_link_active }}{% endif %} {{ class_item_animate }}"
                      >
                        {{ link.title | escape }}
                        {{- icon_arrow -}}
                      </summary>
                      <div
                        id="link-{{ link.handle | escape }}"
                        class="menu-drawer__submenu has-submenu motion-reduce"
                        tabindex="-1"
                      >
                        <div class="menu-drawer__inner-submenu">
                          <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                            {{- icon_arrow -}}
                            {{ link.title | escape }}
                          </button>
                          {%- if has_mega_menu -%}
                            <div class="menu-drawer__mega-menu-desktop" style="padding: 1.5rem 0;">
                              {%- if mega_type == 'mega_menu_1' -%}
                                {%- render 'header-mega-menu-1', section_fetch: true, forloopIndex: forloop.index, link: link, block: mega_block, icon_type: 'caret', keys: keys, sec_settings: section.settings, block_id: 'Drawer' -%}
                              {%- elsif mega_type == 'mega_menu_2' -%}
                                {%- render 'header-mega-menu-2', section_fetch: true, forloopIndex: forloop.index, link: link, block: mega_block, icon_type: 'caret', keys: keys, sec_settings: section.settings, block_id: 'Drawer' -%}
                              {%- elsif mega_type == 'mega_menu_3' -%}
                                {%- render 'header-mega-menu-3', section_fetch: true, forloopIndex: forloop.index, link: link, block: mega_block, icon_type: 'caret', keys: keys, sec_settings: section.settings, block_id: 'Drawer' -%}
                              {%- elsif mega_type == 'mega_menu_4' -%}
                                {%- render 'header-mega-menu-4', section_fetch: true, forloopIndex: forloop.index, link: link, block: mega_block, icon_type: 'caret', keys: keys, sec_settings: section.settings, block_id: 'Drawer' -%}
                              {%- endif -%}
                            </div>
                          {%- else -%}
                            <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                              <li>
                                <a
                                  id="Goto-HeaderDrawer-{{ link.handle }}"
                                  href="{{ link.url }}"
                                  class="{{ class_link }} link--go-to"
                                  {% if childlink.current %}
                                    aria-current="page"
                                  {% endif %}
                                >
                                  {{ 'content.go_to' | t: name: link.title }}
                                </a>
                              </li>
                              {%- for childlink in link.links -%}
                                <li>
                                  {%- if childlink.links == blank -%}
                                    <a
                                      id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                      href="{{ childlink.url }}"
                                      class="{{ class_link }}{% if childlink.current %} {{ class_link_active }}{% endif %}"
                                      {% if childlink.current %}
                                        aria-current="page"
                                      {% endif %}
                                    >
                                      {{ childlink.title | escape }}
                                    </a>
                                  {%- else -%}
                                    <details id="Details-menu-drawer-{{ link.handle }}-{{ childlink.handle }}">
                                      <summary
                                        id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                        class="{{ class_link }}"
                                      >
                                        {{ childlink.title | escape }}
                                        {{- icon_arrow -}}
                                      </summary>
                                      <div
                                        id="childlink-{{ childlink.handle | escape }}"
                                        class="menu-drawer__submenu has-submenu motion-reduce"
                                      >
                                        <button
                                          class="menu-drawer__close-button link link--text focus-inset"
                                          aria-expanded="true"
                                        >
                                          {{- icon_arrow -}}
                                          {{ childlink.title | escape }}
                                        </button>
                                        <ul
                                          class="menu-drawer__menu list-menu"
                                          role="list"
                                          tabindex="-1"
                                        >
                                          <li>
                                            <a
                                              id="Goto-HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                              href="{{ childlink.url }}"
                                              class="{{ class_link }} link--go-to"
                                              {% if grandchildlink.current %}
                                                aria-current="page"
                                              {% endif %}
                                            >
                                              {{ 'content.go_to' | t: name: childlink.title }}
                                            </a>
                                          </li>
                                          {%- for grandchildlink in childlink.links -%}
                                            <li>
                                              <a
                                                id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                                href="{{ grandchildlink.url }}"
                                                class="{{ class_link }}{% if grandchildlink.current %} {{ class_link_active }}{% endif %}"
                                                {% if grandchildlink.current %}
                                                  aria-current="page"
                                                {% endif %}
                                              >
                                                {{ grandchildlink.title | escape }}
                                              </a>
                                            </li>
                                          {%- endfor -%}
                                        </ul>
                                      </div>
                                    </details>
                                  {%- endif -%}
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      </div>
                    </details>
                  {%- else -%}
                    <a
                      id="HeaderDrawer-{{ link.handle }}"
                      href="{{ link.url }}"
                      class="{{ class_link }}{% if link.current %} {{ class_link_active }}{% endif %} {{ class_item_animate }}"
                      {% if link.current %}
                        aria-current="page"
                      {% endif %}
                    >
                      {{ link.title | escape }}
                    </a>
                  {%- endif -%}
                </menu-drawer>
              {%- endfor -%}
            </ul>
          </nav>
          {%- render 'menu-drawer-utility',
            sec_settings: section.settings,
            listmenu_size: listmenu_size,
            class_animated: class_item_animate,
            section_id: section_id
          -%}
        </div>
      </div>
    </div>
  </header-drawer>
</side-drawer>

<style>
  .side-drawer--custom .drawer__inner {
    background-color: #f4f1ea;
  }
  .side-drawer--custom .drawer__search-bar {
    padding: 2rem 2rem 1rem !important;
  }
  .side-drawer--custom .drawer__wrapper {
    padding: 0 !important;
  }
  .side-drawer--custom .search-drawer__form .field {
    background-color: #ffffff;
    border-radius: 2px;
  }
  .side-drawer--custom .search-drawer__form .field:before,
  .side-drawer--custom .search-drawer__form .field:after {
    display: none;
  }
  .side-drawer--custom .search-drawer__form .field__input {
    padding: 1.2rem 1.5rem;
    font-size: 1.3rem;
  }
  .side-drawer--custom .search-drawer__form .search__button {
    display: none;
  }
  .side-drawer--custom .menu-drawer__menu-item {
    padding: 1.2rem 2rem;
    font-size: 1.4rem;
    color: #1a2a3a;
  }
  .side-drawer--custom .menu-drawer__menu-item > .svg-wrapper {
    right: 2rem;
  }
  
  .side-drawer-container--custom {
    top: var(--header-bottom-offset, calc(var(--header-height, 100%) + var(--announcement-bar-height, 0px))) !important;
    height: calc(100vh - var(--header-bottom-offset, calc(var(--header-height, 100%) + var(--announcement-bar-height, 0px)))) !important;
  }
  .side-drawer-container--custom .drawer__overlay {
    display: none !important;
  }
  .side-drawer-container--custom .side-drawer--custom {
    width: 100vw !important;
    max-width: 100% !important;
  }
</style>

{%- if mobile_layout == 'custom' -%}
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const setAnnouncementHeight = () => {
      const announcementBar = document.querySelector('.section-announcement-bar');
      if (announcementBar) {
        document.documentElement.style.setProperty('--announcement-bar-height', `${announcementBar.offsetHeight}px`);
      } else {
        document.documentElement.style.setProperty('--announcement-bar-height', '0px');
      }
    };
    setAnnouncementHeight();
    window.addEventListener('resize', setAnnouncementHeight);

    const opener = document.querySelector('side-drawer-opener[data-side-drawer="#Drawer-Menu"] button');
    const container = document.querySelector('#Drawer-Menu.side-drawer-container--custom');
    if (opener && container) {
      opener.addEventListener('click', () => {
        const header = document.querySelector('.header-wrapper') || document.querySelector('header');
        if (header) {
          const rect = header.getBoundingClientRect();
          container.style.setProperty('--header-bottom-offset', `${rect.bottom}px`);
        }
      });
    }
  });
</script>
{%- endif -%}
